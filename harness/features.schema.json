{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "engineering-workflow features",
  "type": "object",
  "required": ["features"],
  "properties": {
    "_doc": { "type": "string" },
    "$schema": { "type": "string" },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "acceptance", "priority", "passes"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F[0-9]{3,4}$",
            "description": "Stable identifier, e.g. F001"
          },
          "title": {
            "type": "string",
            "maxLength": 80,
            "description": "Imperative one-line title"
          },
          "description": {
            "type": "string",
            "description": "1-3 sentence prose description"
          },
          "acceptance": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Testable bullets; each must be verifiable by the tester"
          },
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2"]
          },
          "passes": {
            "type": "boolean",
            "description": "true only after tester provides evidence for every acceptance bullet"
          },
          "owner": {
            "type": ["string", "null"],
            "description": "Session id of the agent currently building this; null when unclaimed"
          },
          "worktree": {
            "type": ["string", "null"],
            "description": "Path to the git worktree if /parallel was used; null otherwise"
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional list of feature ids that must pass first"
          }
        }
      }
    }
  }
}
